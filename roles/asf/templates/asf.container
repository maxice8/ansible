[Unit]
Description=ArchiSteamFarm
Requires=ts-asf.service
After=ts-asf.service
BindsTo=ts-asf.service
PartOf=ts-asf.service

[Container]
Image=docker.io/justarchi/archisteamfarm:latest
AutoUpdate=registry

ContainerName=asf

# Attaches ASF to the Tailscale container's network namespace
Network=container:ts-asf
Environment=ASF_UID=1000

Volume=asf-data.volume:/app/config
Volume=/etc/asf/ASF.json:/app/config/ASF.json

# Permissions
NoNewPrivileges=true
DropCapability=all
# Required to fix volume permissions and drop to ASF_UID
AddCapability=CHOWN
AddCapability=FOWNER
AddCapability=DAC_OVERRIDE
# Required for privilege dropping sequence
AddCapability=SETUID
AddCapability=SETGID
ReadOnly=true
Tmpfs=/tmp
# ASF writes logs locally inside the app directory
Tmpfs=/app/logs

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target