[Unit]
Description=Ghost Blog
After=network-online.target

[Container]
Image=docker.io/library/ghost:latest
ContainerName=ghost

# Ports
PublishPort=127.0.0.1:{{ ghost_port }}:2368

# Volumes
Volume=ghost-data.volume:/var/lib/ghost/content

# Environment Variables
Environment=DOMAIN={{ ghost_domain_name }}
Environment=database__client=sqlite3
Environment=database__connection__filename=content/data/ghost.db
Environment=database__useNullAsDefault=true
Environment=database__debug=false
Environment=url=https://{{ ghost_domain_name }}
Environment=mail__transport=SMTP
Environment=mail__options__service=Google
Environment=mail__options__host=smtp.gmail.com
Environment=mail__options__port=587
Environment=mail__options__auth__user={{ ghost_email_user }}
Environment=mail__options__auth__pass={{ ghost_email_pass }}

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target