[Unit]
Description=Forgejo Runner
Requires=dind.service
After=dind.service

[Container]
Image=code.forgejo.org/forgejo/runner:12
AutoUpdate=registry

ContainerName=forgejo-runner

# Attach to the standard network namespace
Network=forgejo-runner.network
HostName=forgejo-runner-{{ inventory_hostname }}

# Run securely natively as the dynamic UID/GID
User={{ forgejo_runner_user_id }}:{{ forgejo_runner_group_id }}

# Environment Variables
Secret=forgejo_runner_token,type=env,target=FORGEJO_RUNNER_TOKEN
# Pointing to the internal DinD container
Environment=DOCKER_HOST=tcp://docker_dind:2375
# Pointing to the public instance URL via Caddy
Environment=FORGEJO_INSTANCE_URL=https://git.{{ domain_name }}

{% if 'forgejo' in configured_services -%}
# Forgejo is on this same host. Force git.{{ domain_name }} to resolve internally.
AddHost=git.{{ domain_name }}:host-gateway
{% endif -%}

# Volume bind for data
Volume=forgejo-runner-data.volume:/data:U

# Custom Entrypoint Command
Volume=/etc/forgejo-runner/config.yml:/data/config.yml:ro,z
Volume=/etc/forgejo-runner/entrypoint.sh:/data/entrypoint.sh:ro,z

# Map host users so the container resolves the dynamic UID correctly
Volume=/etc/passwd:/etc/passwd:ro
Volume=/etc/group:/etc/group:ro

Exec=/bin/sh /data/entrypoint.sh

# Permissions
NoNewPrivileges=true
DropCapability=all
ReadOnly=true
Tmpfs=/tmp

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
