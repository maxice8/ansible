FROM docker.io/library/alpine:latest

# Combine apk and pip steps to reduce image layers
RUN apk add --no-cache \
    borgbackup \
    openssh-client \
    python3 \
    py3-pip \
    tzdata \
    ca-certificates && \
    python3 -m venv /opt/borgmatic-venv && \
    /opt/borgmatic-venv/bin/pip install --no-cache-dir "borgmatic[apprise]"

# Add the venv to the path so 'borgmatic' is found automatically
ENV PATH="/opt/borgmatic-venv/bin:$PATH"

ENTRYPOINT ["borgmatic"]