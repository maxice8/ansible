{
    {% if caddy_crowdsec_api_key != "" -%}
    crowdsec {
        # Use the environment variable injected via Podman Secret
        api_key {$CADDY_CROWDSEC_API_KEY}
    }
    order crowdsec first
    {% endif -%}
    servers {
        metrics
    }
    # Global options block
    log {
        output file /var/log/caddy/caddy_main.log {
            roll_size 100MiB
            roll_keep 5
            roll_keep_for 100d
        }
        format json
        level INFO
    }
}

:2019 {
    metrics
}

# Health check
{{ domain_name }} {
    respond /_health 200
}

pomerium.{{ domain_name }} {
    reverse_proxy localhost:{{ pomerium_port }} {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
    
    {% if caddy_crowdsec_api_key != "" -%}
    route {
        crowdsec
    }
    {% endif -%}
}

cockpit.{{ inventory_hostname }}.{{ domain_name }} {
    reverse_proxy localhost:{{ pomerium_port }} {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
    
    {% if caddy_crowdsec_api_key != "" -%}
    route {
        crowdsec
    }
    {% endif -%}
}

