[Unit]
Description=Caddy Web Server
After=network-online.target caddy-build.service
Requires=caddy-build.service

[Container]
Image=localhost/caddy-custom:latest
ContainerName=caddy

AutoUpdate=local

{% if caddy_crowdsec_api_key != "" -%}
Secret=caddy_crowdsec_api_key,type=env,target=CADDY_CROWDSEC_API_KEY
{% endif -%}

# Essential for binding to 80/443 and proxying to localhost services
Network=host

# Configuration and Persistence
Volume=/etc/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
Volume=caddy-data.volume:/data
# Map host log directory so CrowdSec can still read logs
Volume=/var/log/caddy:/var/log/caddy:rw
# Permissions
NoNewPrivileges=true
DropCapability=all
AddCapability=NET_BIND_SERVICE
# Allow log rotation
AddCapability=DAC_OVERRIDE
AddCapability=FOWNER
AddCapability=CHOWN
ReadOnly=true
Tmpfs=/tmp
Tmpfs=/config

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target