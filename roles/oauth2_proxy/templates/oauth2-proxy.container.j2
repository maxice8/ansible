[Unit]
Description=OAuth2 Proxy (OIDC Gatekeeper)
After=network-online.target

[Container]
Image=quay.io/oauth2-proxy/oauth2-proxy:latest
AutoUpdate=registry
ContainerName=oauth2-proxy

# Use host network to easily communicate with Caddy
Network=host

# Listen locally
Environment=OAUTH2_PROXY_HTTP_ADDRESS=127.0.0.1:4180

# OIDC Integration (Using your Pocket ID domain)
Environment=OAUTH2_PROXY_PROVIDER=oidc
Environment=OAUTH2_PROXY_OIDC_ISSUER_URL=https://id.{{ domain_name }}
Environment=OAUTH2_PROXY_CLIENT_ID={{ oauth2_proxy_client_id }}
Secret=oauth2_proxy_client_secret,type=env,target=OAUTH2_PROXY_CLIENT_SECRET
Secret=oauth2_proxy_cookie_secret,type=env,target=OAUTH2_PROXY_COOKIE_SECRET

# Proxy behavior 
Environment=OAUTH2_PROXY_REVERSE_PROXY=true
Environment=OAUTH2_PROXY_EMAIL_DOMAINS=*
# Allow auth cookies to be valid across your domain
Environment=OAUTH2_PROXY_WHITELIST_DOMAINS=.{{ domain_name }}
Environment=OAUTH2_PROXY_COOKIE_DOMAIN=.{{ domain_name }}
Environment=OAUTH2_PROXY_COOKIE_SECURE=true
# Skips the intermediate "Login with OIDC" page and goes straight to Pocket ID
Environment=OAUTH2_PROXY_SKIP_PROVIDER_BUTTON=true

# Provide a dummy upstream so the container doesn't crash on startup
Environment=OAUTH2_PROXY_UPSTREAMS=file:///dev/null

[Service]
Restart=always
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
