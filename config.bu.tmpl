variant: fcos
version: 1.5.0
passwd:
  users:
    - name: core
      ssh_authorized_keys:
        - "${SSH_PUB_KEY}"
storage:
  files:
    # --- DYNAMIC HOSTNAME ---
    - path: /etc/hostname
      mode: 0644
      contents:
        inline: ${HOSTNAME}
        
    - path: /etc/NetworkManager/system-connections/public-network.nmconnection
      mode: 0600
      contents:
        inline: |
          [connection]
          id=public-network
          type=ethernet
          
          [ethernet]
          mac-address=${MAC_ADDRESS}
          
          [ipv4]
          address1=${IPV4_ADDRESS},${IPV4_GATEWAY}
          dns=8.8.8.8;1.1.1.1;
          method=manual
          
          [ipv6]
          method=auto

systemd:
  units:
    - name: layer-system-packages.service
      enabled: true
      contents: |
        [Unit]
        Description=Layer system packages live via rpm-ostree
        Wants=network-online.target
        After=network-online.target
        ConditionPathExists=!/var/lib/pkgs-layered

        [Service]
        Type=oneshot
        RemainAfterExit=yes
        ExecStart=/bin/sh -c 'echo "enable tailscaled.service" > /etc/systemd/system-preset/99-tailscale.preset'
        ExecStart=/bin/sh -c 'echo "enable cockpit.socket" > /etc/systemd/system-preset/99-cockpit.preset'
        ExecStart=/usr/bin/rpm-ostree install -y --idempotent --allow-inactive python3 tailscale cockpit-ws cockpit-system cockpit-podman
        ExecStart=/usr/bin/touch /var/lib/pkgs-layered
        ExecStart=/usr/bin/systemctl reboot

        [Install]
        WantedBy=multi-user.target
