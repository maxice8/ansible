{"ignition":{"version":"3.4.0"},"passwd":{"users":[{"name":"core","sshAuthorizedKeys":["ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIIK6ZwJ+jkOR723sGB06cp77HIYsxShCCFUYHNLc8sTx max@sora"]}]},"storage":{"files":[{"path":"/etc/hostname","contents":{"compression":"","source":"data:,ryuu"},"mode":420}]},"systemd":{"units":[{"contents":"[Unit]\nDescription=Layer Python3 and Tailscale live via rpm-ostree\nWants=network-online.target\nAfter=network-online.target\n# We still use the lockfile so we don't delay every future reboot\nConditionPathExists=!/var/lib/pkgs-layered\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\n\n# --apply-live: Applies changes to the booted deployment without reboot.\n# --idempotent: Skips the operation if the request is already applied.\n# --allow-inactive: Permits packages that are already in the base layer in case Fedora adds Python3 to the core image later.\nExecStart=/usr/bin/rpm-ostree install -y --apply-live --idempotent --allow-inactive python3 tailscale\n# Enable and start the tailscaled service immediately after installation to ensure I can 'tailscale up' when I SSH.\nExecStart=/usr/bin/systemctl enable --now tailscaled.service\n# Create a lockfile to prevent this service from running again on future reboots, which would cause unnecessary delays.\nExecStart=/usr/bin/touch /var/lib/pkgs-layered\n\n[Install]\nWantedBy=multi-user.target","enabled":true,"name":"install-python-and-tailscale.service"}]}}
